<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/
dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.repository.BokiMapper">

    <!-- ランダムid取得 -->
   <select id="findRandomIds" resultType="java.lang.Integer">
       SELECT id FROM boki ORDER BY RANDOM() LIMIT #{limit}
   </select>

    <!-- id全件取得 -->
   <select id="findAll" resultType="com.example.demo.entity.Question">
       SELECT id FROM boki
   </select>

    <!-- 問題1件取得 -->
    <select id="findById" resultType="com.example.demo.entity.Question">
        SELECT * FROM boki WHERE id = #{id}
    </select>
    
</mapper>